# ─────────────────────────────────────────────────────
# MyFinance 환경변수 설정 파일
# 이 파일을 복사해서 .env 로 저장한 뒤 값을 채워주세요
# Railway 배포 시에는 Variables 탭에 직접 입력하세요
# ─────────────────────────────────────────────────────

# ── 필수 ──────────────────────────────────────────────
# 세션 암호화 키 (랜덤 문자열, 반드시 변경할 것)
SECRET_KEY=your-super-secret-key-change-this

# DB (Railway가 PostgreSQL 추가 시 자동 주입됨, 로컬은 비워두면 SQLite 사용)
DATABASE_URL=

# ── Google OAuth (선택) ───────────────────────────────
# https://console.cloud.google.com → API 및 서비스 → OAuth 2.0 클라이언트 ID
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Kakao OAuth (선택) ────────────────────────────────
# https://developers.kakao.com → 내 애플리케이션 → REST API 키
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=

# ── Web Push VAPID 키 (선택) ──────────────────────────
# 로컬에서는 자동 생성됨 (.vapid_keys.json)
# Railway에서는 아래 값을 직접 입력해야 함
# 생성 방법: python -c "from config import _get_vapid_keys; k=_get_vapid_keys(); print(k)"
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=

# ── 오픈뱅킹 (선택) ───────────────────────────────────
# 금융결제원 오픈뱅킹 API 승인 후 발급
# https://developers.openbanking.or.kr
OPENBANKING_CLIENT_ID=
OPENBANKING_CLIENT_SECRET=
